#cloud-config
autoinstall:
  version: 1
  locale: fr_FR.UTF-8
  keyboard:
    layout: fr
  network:
    version: 2
    wifis:
      wifi0:
        match:
          name: "wl*"
        dhcp4: true
        optional: true
        access-points:
          "YOUR_WIFI_SSID":
            password: "YOUR_WIFI_PASSWORD"
  storage:
    layout:
      name: direct          # utilise TOUT le disque du Vero (efface tout)
  identity:
    hostname: vero-ia
    realname: IA
    username: ia
    password: "$6$FX3oQQN.pKr6X25h$T45MpadYn7iDQGoONjeKC5Q.aFGcmj9r2oyCp6TZvW0kFDG3ofjsluX4gPl.SpG798zb3Emtps5rXt9i0sMRt/"     # mot de passe = "ia" -> a changer
  user-data:
    write_files:
      - path: /opt/setup-appliance.sh
        permissions: '0755'
        encoding: b64
        content: 
    runcmd:
      # Choix des applis : 0 = ne pas installer. Le chat IA est toujours installe.
      - [ bash, -c, "INSTALL_FREECAD=1 INSTALL_KRITA=1 INSTALL_VEIKK=1 bash /opt/setup-appliance.sh" ]
